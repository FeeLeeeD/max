# Postgres (local dev)
POSTGRES_USER=max
POSTGRES_PASSWORD=max
POSTGRES_DB=max
DATABASE_URL=postgresql://max:max@localhost:5441/max

# TLS for the Postgres connection. Explicit "true"/"false" wins; if unset it's
# inferred from a sslmode=require (or verify-*) in DATABASE_URL. Leave unset for
# local Docker (no TLS); set true for managed Postgres (Neon/Railway/etc).
# DATABASE_SSL=false

# Apply pending DB migrations on API startup (before it serves traffic).
# Leave false locally (migrations run via `pnpm --filter @max/sandbox db:migrate`);
# set true in cloud so each deploy migrates on boot.
# RUN_MIGRATIONS_ON_BOOT=false

# API HTTP port (default 8000).
# PORT=8000

# CORS allow-list (comma-separated origins). REQUIRED for any browser/widget
# access: if empty/unset the API blocks ALL cross-origin requests (no allow-all
# fallback). Set the local widget dev origin and/or the deployed widget URL.
# ALLOWED_ORIGINS=http://localhost:5173

# Portkey (LLM gateway)
PORTKEY_API_KEY=
PORTKEY_VIRTUAL_KEY=
# Optional: if your Portkey setup requires passing the provider key through
PORTKEY_CONFIG=

# Voyage AI (embeddings) — called directly, no gateway. Get a key at
# https://dashboard.voyageai.com
VOYAGE_API_KEY=

# Refusal threshold: minimum top retrieval score (cosine similarity, range
# [0,1]) required to answer instead of refusing. Optional — unset means 0.55.
# Tune per embedding model; set in Railway to recalibrate without a rebuild.
# REFUSAL_MIN_SCORE=0.55
